{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brekkylab.dev/schemas/confluence.schema.json",
  "title": "BYO corpus record \u2014 confluence",
  "description": "A Confluence page or blogpost. Title -> title, content -> body.storage. `container` is the space. Use `parent` for child pages.",
  "type": "object",
  "properties": {
    "source_type": {
      "const": "confluence"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "description": "The retrieval payload served verbatim as the body."
    },
    "title": {
      "type": "string",
      "description": "Document title (email subject / file name / issue title / page title)."
    },
    "doc_id": {
      "type": "string",
      "description": "Stable id (default: dsid_<sha256(source_type+title+content)>)."
    },
    "space": {
      "type": "string",
      "description": "The space this document belongs to (default: the source_type)."
    },
    "group": {
      "type": "string",
      "description": "ACL group owning the space (default: slug(container))."
    },
    "author_email": {
      "type": "string",
      "format": "email",
      "description": "Author / sender / owner."
    },
    "author_name": {
      "type": "string"
    },
    "author_groups": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Groups the author belongs to."
    },
    "visibility": {
      "enum": [
        "public",
        "group",
        "private"
      ],
      "description": "public = org-wide, group = the container's group, private = author only."
    },
    "readers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Explicit reader principals (emails -> users, else group ids). Overrides visibility."
    },
    "meta": {
      "type": "object",
      "description": "Free-form per-source structured extras merged into the record."
    },
    "subtype": {
      "enum": [
        "page",
        "blogpost"
      ],
      "description": "Content type (default: page)."
    },
    "parent": {
      "type": "string",
      "description": "doc_id of the parent page (hierarchy)."
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created": {
      "type": [
        "integer",
        "number",
        "string"
      ],
      "description": "Creation time (epoch seconds or ISO 8601). Default: synthesized from doc_id."
    },
    "updated": {
      "type": [
        "integer",
        "number",
        "string"
      ],
      "description": "version.when / last-modified (epoch seconds or ISO 8601). Default: created + 1h."
    },
    "version_number": {
      "type": "integer",
      "description": "version.number. Default: 2 if updated != created, else 1."
    },
    "version_message": {
      "type": "string",
      "description": "version.message (edit summary)."
    },
    "minor_edit": {
      "type": "boolean",
      "description": "version.minorEdit flag."
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "A comment on the document (served via the vendor's comment API).",
        "properties": {
          "content": {
            "type": "string",
            "minLength": 1,
            "description": "Comment text (alias: body)."
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "description": "Comment text (alias: content)."
          },
          "author_email": {
            "type": "string",
            "format": "email"
          },
          "author_name": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "description": "Optional stable id (default: <doc_id>::c<n>)."
          },
          "created_ts": {
            "type": [
              "integer",
              "number",
              "string"
            ],
            "description": "Optional creation time (epoch seconds or ISO string)."
          }
        },
        "anyOf": [
          {
            "required": [
              "content"
            ]
          },
          {
            "required": [
              "body"
            ]
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "source_type",
    "content",
    "title"
  ],
  "additionalProperties": false
}
