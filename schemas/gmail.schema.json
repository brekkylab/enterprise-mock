{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brekkylab.dev/schemas/gmail.schema.json",
  "title": "BYO corpus record \u2014 gmail",
  "description": "A Gmail message. Title maps to the Subject header; content to the body. Recipients (readers) determine who can read the mailbox item.",
  "type": "object",
  "properties": {
    "source_type": {
      "const": "gmail"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "description": "The retrieval payload served verbatim as the body."
    },
    "title": {
      "type": "string",
      "description": "Document title (email subject / file name / issue title / page title)."
    },
    "doc_id": {
      "type": "string",
      "description": "Stable id (default: dsid_<sha256(source_type+title+content)>)."
    },
    "mailbox": {
      "type": "string",
      "description": "The mailbox this document belongs to (default: the source_type)."
    },
    "group": {
      "type": "string",
      "description": "ACL group owning the mailbox (default: slug(container))."
    },
    "author_email": {
      "type": "string",
      "format": "email",
      "description": "Author / sender / owner."
    },
    "author_name": {
      "type": "string"
    },
    "author_groups": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Groups the author belongs to."
    },
    "visibility": {
      "enum": [
        "public",
        "group",
        "private"
      ],
      "description": "public = org-wide, group = the container's group, private = author only."
    },
    "readers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Explicit reader principals (emails -> users, else group ids). Overrides visibility."
    },
    "meta": {
      "type": "object",
      "description": "Free-form per-source structured extras merged into the record."
    },
    "thread": {
      "type": "string",
      "description": "Thread id (default: the doc_id)."
    },
    "label_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Gmail label ids."
    },
    "cc": {
      "type": "string",
      "description": "Cc header."
    },
    "bcc": {
      "type": "string",
      "description": "Bcc header."
    },
    "reply_to": {
      "type": "string",
      "description": "Reply-To header."
    },
    "message_id": {
      "type": "string",
      "description": "RFC822 Message-ID header."
    },
    "in_reply_to": {
      "type": "string",
      "description": "In-Reply-To header."
    },
    "references": {
      "type": [
        "array",
        "string"
      ],
      "description": "References header (thread chain)."
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "[{filename, mime, size, content}]."
    },
    "to": {
      "type": "string",
      "description": "To header (default: <mailbox>@<org_domain>)."
    },
    "html": {
      "type": "string",
      "description": "HTML body for the text/html MIME part (default: content wrapped in <p>)."
    },
    "created": {
      "type": [
        "integer",
        "number",
        "string"
      ],
      "description": "Sent/received time (epoch seconds or ISO 8601). Default: synthesized. Drives Date + internalDate."
    }
  },
  "required": [
    "source_type",
    "content",
    "title"
  ],
  "additionalProperties": false
}
