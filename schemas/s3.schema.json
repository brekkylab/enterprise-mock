{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brekkylab.dev/schemas/s3.schema.json",
  "title": "BYO corpus record — s3",
  "description": "An S3 object. content -> the object body (served verbatim by GetObject). `bucket` is the grouping/ACL unit; `key` is the object key/path within the bucket.",
  "type": "object",
  "properties": {
    "source_type": {
      "const": "s3"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "description": "The object body, served verbatim."
    },
    "title": {
      "type": "string",
      "description": "Human title (metadata; the key is the address)."
    },
    "key": {
      "type": "string",
      "minLength": 1,
      "description": "The object key (path within the bucket)."
    },
    "doc_id": {
      "type": "string",
      "description": "Stable id (default: dsid_<sha256(source_type+title+content)>)."
    },
    "bucket": {
      "type": "string",
      "description": "The bucket this object belongs to (default: the source_type)."
    },
    "group": {
      "type": "string",
      "description": "ACL group owning the bucket (default: slug(bucket))."
    },
    "author_email": {
      "type": "string",
      "format": "email",
      "description": "Object owner."
    },
    "author_name": {
      "type": "string"
    },
    "author_groups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "visibility": {
      "enum": [
        "public",
        "group",
        "private"
      ],
      "description": "public = org-wide, group = the bucket's group, private = owner only."
    },
    "readers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Explicit reader principals. Overrides visibility."
    },
    "meta": {
      "type": "object"
    },
    "subtype": {
      "type": "string",
      "description": "Storage-class label (default: STANDARD)."
    },
    "content_type": {
      "type": "string",
      "description": "MIME type for GetObject/HeadObject (default: text/plain)."
    },
    "size": {
      "type": [
        "integer",
        "number"
      ],
      "description": "Byte length (default: computed from content)."
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created": {
      "type": [
        "integer",
        "number",
        "string"
      ],
      "description": "Creation time (epoch seconds or ISO 8601)."
    },
    "updated": {
      "type": [
        "integer",
        "number",
        "string"
      ],
      "description": "Last-Modified (epoch seconds or ISO 8601)."
    }
  },
  "required": [
    "source_type",
    "content",
    "title",
    "key"
  ],
  "additionalProperties": false
}
