# Copy to `.env` and fill in as needed. `.env` is gitignored.
#
# ── LLM API keys (only for examples/using-mcp-with-agents/) ──────────────────
# The mock server itself needs NO API keys. These are only read by the agent
# example scripts that drive an LLM against the mock.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Mock server settings (all optional; MOCK_-prefixed, see app/config.py) ───
# Sensible defaults are baked in; override only when you need to.
#
# Org identity is normally derived from the corpus's dominant email domain.
# Set these to override the derivation entirely:
# MOCK_ORG_NAME=example
# MOCK_ORG_DOMAIN=example.com
#
# Auth: a caller presenting the admin token bypasses ACL filtering.
# MOCK_ADMIN_TOKEN=admin-service-token
# MOCK_ENFORCE_ACL=true
# MOCK_EXPOSE_TOKENS=true
#
# Paths (defaults resolve under the repo's data/ dir):
# MOCK_DATA_DIR=./data
# MOCK_RAW_DIR=./data/raw
